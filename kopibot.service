[Unit]
Description=KopiBot SaaS Platform
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/kopibot
ExecStart=/root/kopibot/venv/bin/python3 run_platform.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kopibot

[Install]
WantedBy=multi-user.target
